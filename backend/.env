# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ruralcare_triage"

# JWT
JWT_SECRET="change-this-to-a-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="24h"

# OpenAI (used for Whisper STT, GPT, TTS)
OPENAI_API_KEY="sk-..."

# OCR (Google Cloud Vision)
GOOGLE_CLOUD_VISION_API_KEY="..."
# OR use Tesseract (local, no key needed) — set OCR_ENGINE=tesseract
OCR_ENGINE="google_vision"

# Upload limits
MAX_FILE_SIZE_MB=5

# CORS
CORS_ORIGIN="http://localhost:5173"
